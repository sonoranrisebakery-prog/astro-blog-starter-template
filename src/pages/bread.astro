---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={`Our Bread | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
</head>

<body>
	<Header />

	<main>
		<h1>Our Bread</h1>
		<p>
			A new food tradition rising from the Sonoran Desert.
		</p>
	</main>

	<Footer />
</body>
</html>